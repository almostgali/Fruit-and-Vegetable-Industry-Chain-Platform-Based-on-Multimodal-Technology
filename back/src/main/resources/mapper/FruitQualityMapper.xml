<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.back.mapper.FruitQualityMapper">

    <resultMap id="BaseResultMap" type="org.back.entity.FruitQuality">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="user_id" property="userId" jdbcType="BIGINT"/>
        <result column="image_url" property="imageUrl" jdbcType="VARCHAR"/>
        <result column="category" property="category" jdbcType="VARCHAR"/>
        <result column="maturity" property="maturity" jdbcType="VARCHAR"/>
        <result column="sweetness" property="sweetness" jdbcType="VARCHAR"/>
        <result column="result" property="result" jdbcType="VARCHAR"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, image_url, category, maturity, sweetness, result, create_time, update_time
    </sql>

    <insert id="insert" parameterType="org.back.entity.FruitQuality" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO fruit_quality_detection (user_id, image_url, category, maturity, sweetness, result, create_time, update_time)
        VALUES (#{userId}, #{imageUrl}, #{category}, #{maturity}, #{sweetness}, #{result}, #{createTime}, #{updateTime})
    </insert>

    <select id="selectById" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM fruit_quality_detection
        WHERE id = #{id}
    </select>

    <select id="selectByUserId" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM fruit_quality_detection
        WHERE user_id = #{userId}
        ORDER BY create_time DESC
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM fruit_quality_detection
        ORDER BY create_time DESC
    </select>

    <update id="updateById" parameterType="org.back.entity.FruitQuality">
        UPDATE fruit_quality_detection
        SET user_id = #{userId},
            image_url = #{imageUrl},
            category = #{category},
            maturity = #{maturity},
            sweetness = #{sweetness},
            result = #{result},
            update_time = #{updateTime}
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM fruit_quality_detection WHERE id = #{id}
    </delete>

</mapper>